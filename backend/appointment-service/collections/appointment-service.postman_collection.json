{
  "info": {
    "name": "Appointment Service",
    "description": "Requests for the appointment-service API (create, list, find by id, update status).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "appointmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create appointment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "11111111-1111-1111-1111-111111111111" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientCpf\": \"52998224725\",\n  \"patientName\": \"John Doe\",\n  \"scheduledAt\": \"2027-01-01T10:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointment",
              "host": ["{{baseUrl}}"],
              "path": ["appointment"]
            }
          }
        },
        {
          "name": "List appointments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List appointments filtered by status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        },
        {
          "name": "Get appointment by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}"]
            }
          }
        },
        {
          "name": "Update status - confirm",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "status"]
            }
          }
        },
        {
          "name": "Update status - cancel",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELED\",\n  \"observation\": \"Patient requested cancellation\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "status"]
            }
          }
        },
        {
          "name": "Update status - back to pending",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PENDING\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Error scenarios",
      "item": [
        {
          "name": "Create without Idempotency-Key -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientCpf\": \"52998224725\",\n  \"patientName\": \"John Doe\",\n  \"scheduledAt\": \"2027-01-01T10:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointment",
              "host": ["{{baseUrl}}"],
              "path": ["appointment"]
            }
          }
        },
        {
          "name": "Create with invalid CPF -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "22222222-2222-2222-2222-222222222222" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientCpf\": \"12345678900\",\n  \"patientName\": \"John Doe\",\n  \"scheduledAt\": \"2027-01-01T10:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointment",
              "host": ["{{baseUrl}}"],
              "path": ["appointment"]
            }
          }
        },
        {
          "name": "Cancel without observation -> 409",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "status"]
            }
          }
        },
        {
          "name": "Get unknown id -> 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    }
  ]
}
